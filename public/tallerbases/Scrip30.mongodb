use ("sample_airbnb") 

db.listingsAndReviews.aggregate([ 
  { 
    $match: { 
      last_review: { 
        $exists: true, 
        $ne: null, 
        $type: "date" 
      } 
    } 
  }, 
  { 
    $group: { 
      _id: { $year: "$last_review" }, 
      cantidad_listings: { $sum: 1 } 
    } 
  }, 
  { $sort: { _id: 1 } }, 
  { 
    $project: { 
      _id: 0, 
      anio: "$_id", 
      cantidad_listings: 1 
    } 
  } 
])
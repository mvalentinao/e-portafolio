<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inicio | E-Portafolio · BD2</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0d0f14; --surface: #141720; --surface2: #1c2030;
      --border: #252b3d; --accent: #f0c96a; --accent-dim: rgba(240,201,106,0.12);
      --text: #e2e6f0; --muted: #6b7394; --subtle: #3a4060;
    }
    body { background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; min-height: 100vh; }
    .site-header {
      border-bottom: 1px solid var(--border); padding: 18px 40px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; background: rgba(13,15,20,0.92);
      backdrop-filter: blur(12px); z-index: 100;
    }
    .logo { font-size: 0.78rem; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); }
    .header-nav { display: flex; gap: 28px; }
    .header-nav a { text-decoration: none; color: var(--muted); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; transition: color 0.2s; }
    .header-nav a:hover, .header-nav a.active { color: var(--text); }
    .hero {
      max-width: 1000px; margin: 0 auto; padding: 100px 40px 80px;
      display: flex; flex-direction: column; align-items: flex-start;
    }
    .hero-eyebrow { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 20px; }
    .hero-title { font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 800; line-height: 1.05; margin-bottom: 20px; letter-spacing: -2px; }
    .hero-title span { color: var(--accent); }
    .hero-sub { color: var(--muted); font-size: 1rem; max-width: 460px; line-height: 1.75; margin-bottom: 48px; }
    .cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
    .cta-primary {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 28px; background: var(--accent); color: #0d0f14;
      font-family: 'IBM Plex Mono', monospace; font-size: 0.82rem; font-weight: 600;
      letter-spacing: 0.5px; text-decoration: none; border-radius: 10px;
      transition: opacity 0.2s;
    }
    .cta-primary:hover { opacity: 0.85; }
    .cta-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 28px; background: transparent; color: var(--muted);
      font-family: 'IBM Plex Mono', monospace; font-size: 0.82rem; font-weight: 600;
      letter-spacing: 0.5px; text-decoration: none; border-radius: 10px;
      border: 1px solid var(--border); transition: all 0.2s;
    }
    .cta-secondary:hover { border-color: var(--subtle); color: var(--text); }
    .divider { max-width: 1000px; margin: 0 auto; padding: 0 40px; border-top: 1px solid var(--border); }
    .stats { max-width: 1000px; margin: 0 auto; padding: 60px 40px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .stat { background: var(--surface); padding: 32px 28px; }
    .stat-num { font-size: 2.4rem; font-weight: 800; color: var(--accent); letter-spacing: -1px; margin-bottom: 4px; }
    .stat-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.7rem; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; }
    @media (max-width: 600px) {
      .site-header { padding: 16px 20px; }
      .hero { padding: 60px 20px 48px; }
      .stats { grid-template-columns: 1fr; padding: 0 20px; }
      .divider { padding: 0 20px; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <span class="logo">E-Portafolio · BD2</span>
    <nav class="header-nav">
      <a href="/e-portafolio/" class="active">Inicio</a>
      <a href="/e-portafolio/presentacion">Presentación</a>
      <a href="/e-portafolio/evidencia">Evidencias</a>
    </nav>
  </header>

  <section class="hero">
    <p class="hero-eyebrow">
    <h1 class="hero-title">E-Portafolio<br/><span>Bases de Datos II</span></h1>
    <p class="hero-sub">Colección de ejercicios, consultas y proyectos del curso: SQL relacional, PL/SQL procedimental y MongoDB NoSQL.</p>
    <div class="cta-row">
      <a href="/e-portafolio/evidencia" class="cta-primary">Ver Evidencias →</a>
      <a href="/e-portafolio/presentacion" class="cta-secondary">Presentación</a>
    </div>
  </section>

  <div class="divider"></div>

  <div class="stats">
    <div class="stat">
      <div class="stat-num">10+</div>
      <div class="stat-label">Ejercicios SQL & PL/SQL</div>
    </div>
    <div class="stat">
      <div class="stat-num">3</div>
      <div class="stat-label">Ejercicios MongoDB</div>
    </div>
    <div class="stat">
      <div class="stat-num">1</div>
      <div class="stat-label">Proyecto Final</div>
    </div>
  </div>
</body>
</html>

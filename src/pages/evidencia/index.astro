---
import "../../styles/index.css";
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Evidencias | E-Portafolio · BD2</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">

  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Syne:wght@400;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>

<body>

  <header class="site-header">

    <span class="logo">
      E-Portafolio · BD2
    </span>

    <nav class="header-nav">
      <a href="/e-portafolio/">Inicio</a>

      <a href="/e-portafolio/presentacion">
        Presentación
      </a>

      <a href="/e-portafolio/evidencia" class="active">
        Evidencias
      </a>
    </nav>

  </header>

  <section class="hero">

    <p class="hero-eyebrow">
      Base de Datos II
    </p>

    <h1 class="hero-title">
      Evidencias
      <br />
      <span>& Ejercicios</span>
    </h1>

    <p class="hero-sub">
      Explora los ejercicios y proyectos organizados
      por tecnología y tema.
    </p>

  </section>

  <div class="grid">

    <!-- SQL -->

    <a href="/e-portafolio/evidencia/sql" class="ev-card sql">

      <span class="badge badge-sql">
        SQL
      </span>

      <h2>
        SQL Relacional
      </h2>

      <p>
        Consultas con JOINs, funciones de agregación,
        subconsultas y manipulación de cadenas en Oracle HR.
      </p>

      <span class="arrow">
        →
      </span>

    </a>

    <!-- PLSQL -->

    <a href="/e-portafolio/evidencia/plsql" class="ev-card plsql">

      <span class="badge badge-plsql">
        PL/SQL
      </span>

      <h2>
        PL/SQL
      </h2>

      <p>
        Sistema de Liquidación de Nómina — package PKG_NOMINA,
        funciones, stored procedures, compound trigger y
        pipelined table function sobre Oracle 19c.
      </p>

      <span class="arrow">
        →
      </span>

    </a>

    <!-- MONGODB -->

    <a href="/e-portafolio/evidencia/nosql" class="ev-card mongo">

      <span class="badge badge-mongo">
        MongoDB
      </span>

      <h2>
        NoSQL / MongoDB
      </h2>

      <p>
        Inserción masiva con insertMany, consultas con operadores
        $lte y $all sobre colecciones reales de Airbnb.
      </p>

      <span class="arrow">
        →
      </span>

    </a>

    <!-- PROYECTO -->

    <a href="/e-portafolio/evidencia/proyecto" class="ev-card proyecto">

      <span class="badge badge-proj">
        Proyecto
      </span>

      <h2>
        Proyecto Final
      </h2>

      <p>
        Sistema Nexus — marketplace integrado con Python,
        MySQL y MongoDB desarrollado en equipo.
      </p>

      <span class="arrow">
        →
      </span>

    </a>

    <!-- TALLERES -->

    <a href="/e-portafolio/evidencia/talleres" class="ev-card talleres">

      <span class="badge badge-taller">
        Talleres
      </span>

      <h2>
        Talleres Aplicados
      </h2>

      <p>
        Ejercicios avanzados de SQL y PL/SQL:
        liquidación de nómina y transacciones ACID
        sobre Oracle Database 19c.
      </p>

      <span class="arrow">
        →
      </span>

    </a>

  </div>

  <div class="footer-area">

    <a class="back-link" href="/e-portafolio/">
      ← Inicio
    </a>

  </div>

</body>
</html>
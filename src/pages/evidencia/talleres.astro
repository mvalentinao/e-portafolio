  <script is:inline define:vars={{ scripts }}>
    window.mongoScripts = scripts;

    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.script-btn');
      const nameDisplay = document.getElementById('current-script-name');
      const codeDisplay = document.getElementById('script-code-display');
      const singleDownloadBtn = document.getElementById('single-download-btn');

      function highlightMongo(code) {
        if (!code) return '';
        // Escape HTML
        let escaped = code
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;");
        
        // Highlight strings first (double and single quotes)
        escaped = escaped.replace(/(["'])(.*?)\1/g, '<span class="str">$1$2$1</span>');
        
        // Highlight comments (double slash)
        escaped = escaped.replace(/(\/\/.*)/g, '<span class="cm">$1</span>');
        
        // MongoDB keywords and operations
        const keywords = ['use', 'db', 'insertOne', 'insertMany', 'find', 'findOne', 'updateOne', 'updateMany', 'deleteOne', 'deleteMany', 'aggregate', 'limit', 'sort', 'project', 'match', 'group', 'unwind'];
        keywords.forEach(kw => {
          const regex = new RegExp(`\\b${kw}\\b`, 'g');
          escaped = escaped.replace(regex, `<span class="kw">${kw}</span>`);
        });

        // Types
        const types = ['NumberDecimal', 'ObjectId', 'ISODate'];
        types.forEach(t => {
          const regex = new RegExp(`\\b${t}\\b`, 'g');
          escaped = escaped.replace(regex, `<span class="fn">${t}</span>`);
        });

        // Numbers (only outside HTML tags)
        escaped = escaped.replace(/\b(\d+(?:\.\d+)?)\b(?![^<]*>)/g, '<span class="num">$1</span>');

        return escaped;
      }

      function showScript(index) {
        const script = window.mongoScripts[index];
        if (!script) return;

        nameDisplay.textContent = script.name;
        codeDisplay.innerHTML = highlightMongo(script.content);
        
        // Setup download link
        if (singleDownloadBtn) {
          const blob = new Blob([script.content], { type: 'text/plain' });
          if (singleDownloadBtn.dataset.blobUrl) {
            URL.revokeObjectURL(singleDownloadBtn.dataset.blobUrl);
          }
          const url = URL.createObjectURL(blob);
          singleDownloadBtn.href = url;
          singleDownloadBtn.download = script.name;
          singleDownloadBtn.dataset.blobUrl = url;
        }
      }

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const index = parseInt(btn.getAttribute('data-index'), 10);
          showScript(index);
        });
      });

      // Initialize with the first script
      showScript(0);
    });
  </script>


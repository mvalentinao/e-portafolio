    .code-body .str { color: #c3e88d; }
    .code-body .cm  { color: #464b5d; font-style: italic; }
    .code-body .num { color: #f78c6c; }

    /* DIVIDER */
    .divider-label {
      font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; color: var(--muted);
      letter-spacing: 2px; text-transform: uppercase;
      display: flex; align-items: center; gap: 12px; margin-bottom: 0;
    }
    .divider-label::before, .divider-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    /* FOOTER */
    .footer-area { max-width: 1100px; margin: 0 auto; padding: 0 40px 60px; }
    .back-link { display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: var(--muted); font-size: 0.82rem; font-weight: 600; transition: color 0.2s; }
    .back-link:hover { color: var(--text); }

    /* MONGO VIEWER */
    .mongo-viewer-container {

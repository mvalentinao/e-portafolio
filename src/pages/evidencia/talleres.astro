---
import fs from 'node:fs';
import path from 'node:path';

// Directorio que contiene los scripts
const tallerBasesDir = path.resolve('public/tallerbases');
let scripts = [];

try {
  if (fs.existsSync(tallerBasesDir)) {
    const files = fs.readdirSync(tallerBasesDir);
    // Filtrar archivos .mongodb y ordenar numéricamente
    const mongodbFiles = files.filter(f => f.endsWith('.mongodb') || f.endsWith('.sql'));
    
    mongodbFiles.sort((a, b) => {
      const numA = parseInt(a.replace(/\D/g, ''), 10) || 0;
      const numB = parseInt(b.replace(/\D/g, ''), 10) || 0;
      return numA - numB;
    });

    scripts = mongodbFiles.map(file => {
      const filePath = path.join(tallerBasesDir, file);
      const content = fs.readFileSync(filePath, 'utf-8');
      return {
        name: file,
        content: content
      };
    });
  }
} catch (e) {
  console.error("Error leyendo la carpeta tallerbases:", e);
}

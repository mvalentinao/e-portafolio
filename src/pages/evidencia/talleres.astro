        <div class="code-body"><span class="kw">WITH</span> dept_stats <span class="kw">AS</span> (
  <span class="kw">SELECT</span>
    e.department_id,
    <span class="fn">AVG</span>(e.salary)  <span class="kw">AS</span> dept_avg_salary,
    <span class="fn">MAX</span>(e.salary)  <span class="kw">AS</span> dept_max_salary,
    <span class="fn">COUNT</span>(*)       <span class="kw">AS</span> dept_headcount
  <span class="kw">FROM</span> T1_EMPLOYEES e
  <span class="kw">WHERE</span> e.department_id <span class="kw">IS NOT NULL</span>
  <span class="kw">GROUP BY</span> e.department_id
)
<span class="kw">SELECT</span>
  e.employee_id,
  e.first_name || <span class="str">' '</span> || e.last_name  <span class="kw">AS</span> nombre,
  d.department_name,
  e.salary,
  ds.dept_avg_salary,
  <span class="fn">ROUND</span>((ds.dept_avg_salary - e.salary) / ds.dept_avg_salary * <span class="num">100</span>, <span class="num">2</span>) <span class="kw">AS</span> gap_pct
<span class="kw">FROM</span> T1_EMPLOYEES e
<span class="kw">JOIN</span> T1_DEPARTMENTS d  <span class="kw">ON</span> e.department_id = d.department_id
<span class="kw">JOIN</span> dept_stats ds     <span class="kw">ON</span> e.department_id = ds.department_id
<span class="kw">ORDER BY</span> gap_pct <span class="kw">DESC</span>;</div>

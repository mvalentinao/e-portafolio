    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d0f14;
      --surface: #141720;
      --surface2: #1c2030;
      --border: #252b3d;
      --accent: #f0c96a;
      --accent-dim: rgba(240,201,106,0.12);
      --green: #5ec994;
      --green-dim: rgba(94,201,148,0.12);
      --blue: #82aaff;
      --blue-dim: rgba(130,170,255,0.12);
      --orange: #f08060;
      --orange-dim: rgba(240,128,96,0.12);
      --purple: #c792ea;
      --purple-dim: rgba(199,146,234,0.12);
      --text: #e2e6f0;
      --muted: #6b7394;
      --subtle: #3a4060;
    }

    body { background: var(--bg); color: var(--text); font-family: 'Syne', sans-serif; min-height: 100vh; }

    /* HEADER */
    .site-header {
      border-bottom: 1px solid var(--border); padding: 18px 40px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0;
      background: rgba(13,15,20,0.92); backdrop-filter: blur(12px); z-index: 100;
    }
    .logo { font-size: 0.78rem; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); }
    .header-nav { display: flex; gap: 28px; }
    .header-nav a { text-decoration: none; color: var(--muted); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; transition: color 0.2s; }
    .header-nav a:hover, .header-nav a.active { color: var(--text); }

    /* HERO */
    .hero { padding: 72px 40px 48px; max-width: 1100px; margin: 0 auto; }
    .hero-eyebrow { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; display: block; }
    .hero-title { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.05; margin-bottom: 16px; letter-spacing: -1.5px; }
    .hero-title span { color: var(--accent); }
    .hero-sub { color: var(--muted); font-size: 0.95rem; max-width: 520px; line-height: 1.7; }

    /* LAYOUT */
    .main { max-width: 1100px; margin: 0 auto; padding: 0 40px 80px; display: flex; flex-direction: column; gap: 32px; }

    /* TALLER CARD */
    .taller {
      background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
      overflow: hidden; animation: slideUp 0.4s ease both;
    }
    .taller:nth-child(1) { animation-delay: .05s; }
    .taller:nth-child(2) { animation-delay: .10s; }
    .taller:nth-child(3) { animation-delay: .15s; }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* TALLER HEADER */
    .taller-head {
      padding: 28px 32px 24px;
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: start;
    }
    .taller-num {
      font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem;
      color: var(--muted); letter-spacing: 2px; text-transform: uppercase;
      margin-bottom: 10px;
    }
    .taller-title { font-size: 1.35rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 8px; }
    .taller-sub { font-size: 0.88rem; color: var(--muted); line-height: 1.65; max-width: 580px; }
    .taller-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
    .badge { padding: 5px 13px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.4px; white-space: nowrap; }
    .badge-plsql  { background: var(--orange-dim); color: var(--orange); }
    .badge-sql    { background: var(--blue-dim);   color: var(--blue); }
    .badge-oracle { background: var(--purple-dim); color: var(--purple); }
    .badge-acid   { background: var(--green-dim);  color: var(--green); }

    /* TALLER BODY */
    .taller-body { padding: 24px 32px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .taller-body.triple { grid-template-columns: repeat(3, 1fr); }

    /* DETAIL BLOCK */
    .detail { display: flex; flex-direction: column; gap: 6px; }
    .detail-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; color: var(--muted); letter-spacing: 1.5px; text-transform: uppercase; }
    .detail-val { font-size: 0.87rem; color: var(--text); line-height: 1.5; }
    .detail-val.mono { font-family: 'IBM Plex Mono', monospace; font-size: 0.8rem; color: var(--accent); }

    /* SECCIONES LIST */
    .sections-list { display: flex; flex-direction: column; gap: 6px; }
    .section-item {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 12px; border-radius: 8px;
      background: var(--surface2); border: 1px solid var(--border);
      font-size: 0.82rem; color: var(--muted);
    }
    .section-num {
      font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem;
      color: var(--accent); min-width: 24px;
    }

    /* TEMAS LIST */
    .temas-list { display: flex; flex-wrap: wrap; gap: 6px; }
    .tema-tag {
      padding: 4px 10px; border-radius: 8px;
      background: var(--surface2); border: 1px solid var(--border);
      font-family: 'IBM Plex Mono', monospace; font-size: 0.7rem; color: var(--muted);
    }

    /* TALLER FOOTER */
    .taller-foot {
      padding: 18px 32px;
      border-top: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      background: var(--surface2);
    }
    .foot-info { font-size: 0.8rem; color: var(--muted); font-family: 'IBM Plex Mono', monospace; }
    .download-btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px;
      background: var(--accent-dim); border: 1px solid var(--accent);
      color: var(--accent); border-radius: 10px;
      font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; font-weight: 600;
      text-decoration: none; letter-spacing: 0.5px;
      transition: background 0.2s, color 0.2s;
    }
    .download-btn:hover { background: var(--accent); color: #0d0f14; }
    .download-btn.blue { background: var(--blue-dim); border-color: var(--blue); color: var(--blue); }
    .download-btn.blue:hover { background: var(--blue); color: #0d0f14; }
    .download-btn.orange { background: var(--orange-dim); border-color: var(--orange); color: var(--orange); }
    .download-btn.orange:hover { background: var(--orange); color: #0d0f14; }
    .btn-group { display: flex; gap: 8px; flex-wrap: wrap; }

    /* CODE PREVIEW */
    .code-preview {
      margin: 0 32px 24px;
      border-radius: 12px; overflow: hidden;
      border: 1px solid var(--border);
    }
    .code-topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 16px; background: var(--surface2); border-bottom: 1px solid var(--border);
    }
    .code-dots { display: flex; gap: 6px; }
    .code-dots span { width: 10px; height: 10px; border-radius: 50%; background: var(--border); }
    .code-lang { font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; }
    .code-body {
      background: #0a0c11; padding: 20px;
      font-family: 'IBM Plex Mono', monospace; font-size: 0.78rem;
      line-height: 1.7; color: #8fa6c8; overflow-x: auto;
      max-height: 200px; overflow-y: auto;

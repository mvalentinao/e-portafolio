      padding-right: 8px;
    }
    .script-selector-grid::-webkit-scrollbar {
      width: 6px;
    }
    .script-selector-grid::-webkit-scrollbar-track {
      background: var(--surface);
      border-radius: 3px;
    }
    .script-selector-grid::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px;
    }
    .script-selector-grid::-webkit-scrollbar-thumb:hover {
      background: var(--muted);
    }
    .script-btn {
      display: flex;
      align-items: center;
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 0 16px;
      height: 38px;
      min-height: 38px;
      border-radius: 8px;
      cursor: pointer;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.78rem;
      line-height: 1;
      text-align: left;
      transition: all 0.2s ease;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .script-btn:hover {
      border-color: var(--accent);
      color: var(--text);
      background: rgba(240, 201, 106, 0.05);
    }
    .script-btn.active {
      background: var(--accent-dim);
      border-color: var(--accent);
      color: var(--accent);
      font-weight: 600;
    }
    .download-script-icon-btn {
      color: var(--muted);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s;
      text-decoration: none;
      padding: 4px;
      border-radius: 4px;
    }
    .download-script-icon-btn:hover {
      color: var(--accent);
      background: var(--border);
    }
    .download-btn.green {
      background: var(--green-dim);
      border-color: var(--green);
      color: var(--green);
    }
    .download-btn.green:hover {
      background: var(--green);
      color: #0d0f14;
    }

    @media (max-width: 768px) {
      .site-header { padding: 16px 20px; }
      .hero { padding: 48px 20px 32px; }
      .main { padding: 0 20px 60px; }
      .footer-area { padding: 0 20px 40px; }
      .taller-head { grid-template-columns: 1fr; }
      .taller-meta { align-items: flex-start; flex-direction: row; flex-wrap: wrap; }
      .taller-body, .taller-body.triple { grid-template-columns: 1fr; }
      .taller-foot { flex-direction: column; align-items: flex-start; }
      .code-preview { margin: 0 20px 20px; }
      .mongo-viewer-container {
        grid-template-columns: 1fr;
        padding: 10px;
      }
      .script-selector-grid {
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        max-height: 180px;
        padding-right: 0;
        margin-bottom: 10px;
      }
      .script-btn {
        justify-content: center;
        font-size: 0.72rem;
        padding: 0 8px;
      }
    }
  </style>
</head>

---
const nombre = "Maria Valentina Osorio Romero";
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Presentación | E-Portafolio · BD2</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d0f14;
      --surface: #141720;
      --surface2: #1c2030;
      --border: #252b3d;
      --accent: #f0c96a;
      --accent-dim: rgba(240,201,106,0.12);
      --text: #e2e6f0;
      --muted: #6b7394;
      --subtle: #3a4060;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Syne', sans-serif;
      min-height: 100vh;
    }

    /* HEADER */
    .site-header {
      border-bottom: 1px solid var(--border);
      padding: 18px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      background: rgba(13,15,20,0.92);
      backdrop-filter: blur(12px);
      z-index: 100;
    }

    .logo {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
    }

    .header-nav { display: flex; gap: 28px; }

    .header-nav a {
      text-decoration: none;
      color: var(--muted);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.5px;
      transition: color 0.2s;
    }

    .header-nav a:hover,
    .header-nav a.active { color: var(--text); }

    /* HERO */
    .hero {
      padding: 72px 40px 48px;
      max-width: 1000px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 16px;
      display: block;
    }

    .hero-title {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800;
      line-height: 1.05;
      margin-bottom: 16px;
      letter-spacing: -1.5px;
    }

    .hero-title span { color: var(--accent); }

    .hero-sub {
      color: var(--muted);
      font-size: 0.95rem;
      max-width: 480px;
      line-height: 1.7;
    }

    /* CONTENT GRID */
    .content {
      max-width: 1000px;
      margin: 0 auto;
      padding: 40px 40px 80px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    /* CARDS */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      transition: border-color 0.2s;
      animation: slideUp 0.35s ease both;
    }

    .card:nth-child(1) { animation-delay: .05s; }
    .card:nth-child(2) { animation-delay: .10s; }
    .card:nth-child(3) { animation-delay: .15s; }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card:hover { border-color: var(--subtle); }

    .card.full { grid-column: 1 / -1; }

    .card-inner { padding: 28px 32px; }

    .card-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .card h2 {
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .card p {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.75;
    }

    /* AVATAR */
    .avatar-card {
      display: flex;
      flex-direction: column;
    }

    .avatar-img-wrap {
      flex: 1;
      min-height: 280px;
      overflow: hidden;
      position: relative;
    }

    .avatar-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
      transition: transform 0.4s ease;
    }

    .avatar-img-wrap img:hover {
      transform: scale(1.03);
    }

    .avatar-badge {
      position: absolute;
      bottom: 16px;
      left: 16px;
      background: rgba(13,15,20,0.85);
      backdrop-filter: blur(8px);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px 14px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem;
      color: var(--accent);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }

    /* INFO CARD */
    .info-card {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .info-name {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      line-height: 1.2;
      margin-bottom: 16px;
    }

    .info-name span { color: var(--accent); }

    .info-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 20px;
    }

    .tag {
      padding: 5px 12px;
      border-radius: 20px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .tag-sql  { background: rgba(94,201,148,0.12);  color: #5ec994; border: 1px solid rgba(94,201,148,0.25); }
    .tag-plsql{ background: rgba(240,128,96,0.12);  color: #f08060; border: 1px solid rgba(240,128,96,0.25); }
    .tag-mongo{ background: rgba(130,170,255,0.12); color: #82aaff; border: 1px solid rgba(130,170,255,0.25); }
    .tag-lang { background: rgba(240,201,106,0.12); color: #f0c96a; border: 1px solid rgba(240,201,106,0.25); }
    .tag-work { background: rgba(180,130,255,0.12); color: #b482ff; border: 1px solid rgba(180,130,255,0.25); }

    /* EXTRA INFO ITEMS */
    .info-items { display: flex; flex-direction: column; gap: 12px; margin-top: 18px; }
    .info-item {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 12px 14px; border-radius: 10px;
      background: var(--surface2); border: 1px solid var(--border);
    }
    .info-item-icon {
      font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem;
      color: var(--accent); letter-spacing: 1px; text-transform: uppercase;
      white-space: nowrap; padding-top: 2px; flex-shrink: 0; min-width: 52px;
    }
    .info-item-text { font-size: 0.84rem; color: var(--muted); line-height: 1.5; }
    .info-item-text strong { color: var(--text); font-weight: 600; }

    /* VIDEO CARD */
    .video-header {
      padding: 24px 32px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .video-header h2 {
      font-size: 1.15rem;
      font-weight: 700;
    }

    .video-live-dot {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .video-live-dot::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #5ec994;
      box-shadow: 0 0 6px #5ec994;
    }

    .video-wrap {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
    }

    .video-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
    }

    /* FOOTER */
    .footer-area {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 40px 60px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.5px;
      transition: color 0.2s;
    }

    .back-link:hover { color: var(--text); }

    /* RESPONSIVE */
    @media (max-width: 700px) {
      .site-header { padding: 16px 20px; }
      .hero         { padding: 48px 20px 32px; }
      .content      { grid-template-columns: 1fr; padding: 24px 20px 60px; }
      .footer-area  { padding: 0 20px 40px; }
      .avatar-img-wrap { min-height: 240px; }
    }
  </style>
</head>
<body>

  <header class="site-header">
    <span class="logo">E-Portafolio · BD2</span>
    <nav class="header-nav">
      <a href="/e-portafolio/">Inicio</a>
      <a href="/e-portafolio/presentacion" class="active">Presentación</a>
      <a href="/e-portafolio/evidencia">Evidencias</a>
    </nav>
  </header>

  <section class="hero">
    <span class="hero-eyebrow">Base de Datos II · 2026</span>
    <h1 class="hero-title">Presentación<br/><span>Personal</span></h1>
    <p class="hero-sub">Conoce más sobre mí y mi trayectoria en el curso de Bases de Datos II.</p>
  </section>

  <div class="content">

    <!-- AVATAR -->
    <div class="card avatar-card">
      <div class="avatar-img-wrap">
        <img src="/e-portafolio/vl.webp" alt="Foto de perfil de {nombre}" />
        <span class="avatar-badge">Estudiante BD2</span>
      </div>
    </div>

    <!-- INFO -->
    <div class="card info-card card-inner">
      <div>
        <div class="card-label">Acerca de mí</div>
        <p class="info-name">{nombre.split(" ").slice(0,2).join(" ")}<br/><span>{nombre.split(" ").slice(2).join(" ")}</span></p>
        <p>Estudiante de Ingeniería de Sistemas con énfasis en Bases de Datos II. Este e-portafolio reúne los ejercicios, consultas y proyectos desarrollados durante el semestre.</p>
        <div class="info-items">
          <div class="info-item">
            <span class="info-item-icon">Idiomas</span>
            <span class="info-item-text"><strong>Portugués</strong> — Facultad de Letras, Universidad de Lisboa</span>
          </div>
          <div class="info-item">
            <span class="info-item-icon">Laboral</span>
            <span class="info-item-text"><strong>Auxiliar Contable</strong> — SENA</span>
          </div>
        </div>
        <div class="info-tags">
          <span class="tag tag-sql">SQL</span>
          <span class="tag tag-plsql">PL/SQL</span>
          <span class="tag tag-mongo">MongoDB</span>
          <span class="tag tag-lang">Portugués</span>
          <span class="tag tag-work">SENA</span>
        </div>
      </div>
    </div>

    <!-- VIDEO -->
    <div class="card full">
      <div class="video-header">
        <div>
          <div class="card-label">Video de presentación</div>
          <h2>Hola mundo</h2>
        </div>
        <span class="video-live-dot">YouTube</span>
      </div>
      <div class="video-wrap">
        <iframe
          src="https://www.youtube.com/embed/IU2qC6zaX2E?si=fwO85uSU9x71Dbd6"
          title="Video de presentación"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>

  </div>

  <div class="footer-area">
    <a class="back-link" href="/e-portafolio/">← Inicio</a>
  </div>

</body>
</html>
